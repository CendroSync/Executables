{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CendrosyncP2P",
  "version": "1.0.0",
  "identifier": "com.cendronyx.cendrosyncp2p",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CendrosyncP2P - Control Center",
        "label": "main",
        "visible": true,
        "width": 840,
        "height": 600,
        "resizable": true,
        "url": "index.html"
      },
      {
        "title": "CendrosyncP2P Quick Sync",
        "label": "popup",
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "width": 340,
        "height": 130,
        "url": "popup.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Cendronyx",
    "copyright": "Copyright © 2026 Cendronyx. All rights reserved.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.png",
        "sidebarImage": "icons/sidebar.png",
        "languages": ["English"]
      }
    }
  }
}
